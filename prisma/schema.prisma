// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SELLER
  BUYER
}

enum WebsiteStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(BUYER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  websites      Website[] @relation("SellerWebsites")
  orders        Order[]   @relation("BuyerOrders")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Website {
  id          String        @id @default(cuid())
  url         String
  category    String
  da          Int           @default(0)   // Domain Authority (Moz)
  dr          Int           @default(0)   // Domain Rating (Ahrefs)
  traffic     Int           @default(0)
  price       Float
  status      WebsiteStatus @default(PENDING)
  sellerId    String
  seller      User          @relation("SellerWebsites", fields: [sellerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  orders      Order[]       @relation("WebsiteOrders")
}

model Order {
  id          String      @id @default(cuid())
  buyerId     String
  buyer       User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  websiteId   String
  website     Website     @relation("WebsiteOrders", fields: [websiteId], references: [id])
  targetUrl   String      // URL the buyer wants to promote
  content     String?     // Optional content/article provided by buyer
  liveLink    String?     // The fulfilled Guest Post URL from seller
  price       Float
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
